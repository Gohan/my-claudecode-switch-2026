# Auto detect text files and perform LF normalization
* text=auto

# Source code - always LF
*.go text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Config files - LF on all platforms
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Makefile requires tabs/LF
Makefile text eol=lf
*.mk text eol=lf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files - don't touch
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
